    "@workspace/db": "workspace:*",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "otplib": "^13.4.1",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "xmlbuilder": "^15.1.1"
