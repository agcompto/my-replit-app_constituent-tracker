    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.28.0",
    "esbuild-plugin-pino": "^2.3.3",
    "fflate": "^0.8.2",
    "pino-pretty": "^13",
    "thread-stream": "4.2.0",
    "vitest": "^4.1.8"
